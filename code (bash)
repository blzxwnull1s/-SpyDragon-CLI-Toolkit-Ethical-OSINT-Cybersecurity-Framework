        16)    tool_my_ip ;;
        17)    tool_domain_to_ip ;;
        18)    tool_email_ip ;;
        0|00)
            echo ""
            echo -e "${BRED}    🐉 SpyDragon cerrando sesión...${RESET}"
            echo -e "${MAGENTA}    Stay ethical. Stay legal.${RESET}"
            echo ""
            exit 0
            ;;
        *)
            echo ""
            echo -e "${RED}    [!] Opción inválida. Intenta de nuevo.${RESET}"
            ;;
    esac

    echo ""
    echo -en "${GRAY}    [Presiona ENTER para continuar...]${RESET}"
    read -r
    print_banner
done

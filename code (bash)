    read -r CUSTOM_NAME
    [[ -n "$CUSTOM_NAME" ]] && REPORT_FILE="$CUSTOM_NAME"
    echo -e "${RESET}"
    {
        echo "============================================"
        echo "  SPYDRAGON - Reporte de Sesión"
        echo "  Fecha: $(date)"
        echo "  Operador: $(whoami)@$(hostname)"
        echo "============================================"
        echo ""
        echo "Herramienta: SpyDragon v1.0"
        echo "Uso: Solo sistemas con autorización expresa"
        echo ""
        echo "Historial de comandos recientes:"
        history 2>/dev/null | tail -20
    } > "$REPORT_FILE"
    echo -e "${BGREEN}    [✓] Reporte guardado en: ${WHITE}$REPORT_FILE${RESET}"
}


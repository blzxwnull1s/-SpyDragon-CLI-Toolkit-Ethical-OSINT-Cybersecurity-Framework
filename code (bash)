        echo -e "${YELLOW}    [*] Leyendo robots.txt de: ${WHITE}$TARGET${RESET}"
        echo ""
        curl -sL "https://${TARGET}/robots.txt" 2>/dev/null | head -40 | sed 's/^/    /'
        echo ""
        echo -e "${CYAN}    -- Sitemap --${RESET}"
        curl -sL "https://${TARGET}/sitemap.xml" 2>/dev/null | grep -oE '<loc>[^<]+</loc>' | head -10 | sed 's/<loc>//g;s/<\/loc>//g' | sed 's/^/    /'

# Rainbow array for cycling
RAINBOW=("$BRED" "$ORANGE" "$YELLOW" "$BGREEN" "$BCYAN" "$BBLUE" "$BMAGENTA")

rainbow_text() {
    local text="$1"
    local i=0
    local len=${#RAINBOW[@]}
    while IFS= read -r -n1 char; do
        echo -en "${RAINBOW[$((i % len))]}${char}"
        ((i++))
    done <<< "$text"
    echo -en "$RESET"
}


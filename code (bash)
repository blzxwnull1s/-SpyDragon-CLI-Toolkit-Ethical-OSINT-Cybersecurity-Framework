check_tool() {
    if ! command -v "$1" &> /dev/null; then
        echo -e "${RED}    [!] '${1}' no está instalado.${RESET}"
        echo -e "${YELLOW}    [*] Instala con: ${WHITE}sudo apt install ${1} ${GRAY}o${WHITE} sudo pacman -S ${1}${RESET}"
        return 1
    fi
    return 0
}

get_target() {
    echo ""
    echo -en "${CYAN}    [>] Ingresa el objetivo (IP/Dominio): ${WHITE}"
    read -r TARGET
    echo -e "${RESET}"
    if [[ -z "$TARGET" ]]; then
        echo -e "${RED}    [!] Objetivo vacío. Cancelando...${RESET}"
        return 1
    fi
    return 0
}

section_header() {
    echo ""
    echo -e "${RED}    ══════════════════════════════════════════════════════${RESET}"
    echo -e "${BRED}    🐉 $1${RESET}"
    echo -e "${RED}    ══════════════════════════════════════════════════════${RESET}"
    echo ""
}

# ---- FUNCIONES ----

tool_ip_info() {
    section_header "IP Info / Lookup"
    get_target || return
    if check_tool curl; then
        echo -e "${YELLOW}    [*] Consultando información de: ${WHITE}$TARGET${RESET}"
        echo ""
        RESULT=$(curl -s "https://ipinfo.io/${TARGET}/json" 2>/dev/null)
        if [[ -n "$RESULT" ]]; then
            echo "$RESULT" | grep -E '"(ip|city|region|country|org|timezone|loc)"' | \
            sed 's/^/    /' | \
            sed "s/\"ip\"/${GREEN}IP${RESET}/g" | \
            sed "s/\"city\"/${YELLOW}Ciudad${RESET}/g" | \
            sed "s/\"region\"/${CYAN}Región${RESET}/g" | \
            sed "s/\"country\"/${BBLUE}País${RESET}/g" | \
            sed "s/\"org\"/${MAGENTA}Organización${RESET}/g" | \
            sed "s/\"timezone\"/${ORANGE}Zona Horaria${RESET}/g" | \
            sed "s/\"loc\"/${BRED}Coordenadas${RESET}/g"
        else
            echo -e "${RED}    [!] No se pudo obtener información.${RESET}"
        fi
    fi
}

tool_whois() {
    section_header "WHOIS - Información de Dominio"
    get_target || return
    if check_tool whois; then
        echo -e "${YELLOW}    [*] Ejecutando WHOIS en: ${WHITE}$TARGET${RESET}"
        echo ""
        whois "$TARGET" 2>/dev/null | grep -iE "registrar|creation|expir|name server|country|registrant|email|updated" | head -20 | sed 's/^/    /'
    fi
}

tool_ping() {
    section_header "Ping - Verificar Host"
    get_target || return
    echo -e "${YELLOW}    [*] Haciendo ping a: ${WHITE}$TARGET${RESET}"
    echo ""
    ping -c 4 "$TARGET" 2>/dev/null | sed 's/^/    /'
}

tool_geoip() {
    section_header "GeoIP - Localización Geográfica"
    get_target || return
    if check_tool curl; then
        echo -e "${YELLOW}    [*] Localizando: ${WHITE}$TARGET${RESET}"
        echo ""
        curl -s "http://ip-api.com/json/${TARGET}?fields=status,country,regionName,city,zip,lat,lon,isp,org,as,query" 2>/dev/null | \
        python3 -m json.tool 2>/dev/null | sed 's/^/    /' || \
        curl -s "http://ip-api.com/json/${TARGET}" 2>/dev/null | sed 's/^/    /'
    fi
}

tool_ssl() {
    section_header "SSL/TLS - Información de Certificado"
    get_target || return
    if check_tool openssl; then
        echo -e "${YELLOW}    [*] Analizando SSL de: ${WHITE}$TARGET${RESET}"
        echo ""
        echo | openssl s_client -connect "${TARGET}:443" -servername "$TARGET" 2>/dev/null | \
        openssl x509 -noout -issuer -subject -dates 2>/dev/null | sed 's/^/    /'
    fi
}

tool_dns() {
    section_header "DNS Lookup"
    get_target || return
    if check_tool dig; then
        echo -e "${YELLOW}    [*] Registros DNS de: ${WHITE}$TARGET${RESET}"
        echo ""
        echo -e "${CYAN}    -- Registro A --${RESET}"
        dig +short A "$TARGET" 2>/dev/null | sed 's/^/    /'
        echo -e "${CYAN}    -- Registro MX --${RESET}"
        dig +short MX "$TARGET" 2>/dev/null | sed 's/^/    /'
        echo -e "${CYAN}    -- Registro NS --${RESET}"
        dig +short NS "$TARGET" 2>/dev/null | sed 's/^/    /'
        echo -e "${CYAN}    -- Registro TXT --${RESET}"
        dig +short TXT "$TARGET" 2>/dev/null | head -5 | sed 's/^/    /'
    elif check_tool nslookup; then
        nslookup "$TARGET" | sed 's/^/    /'
    fi
}

tool_http_headers() {
    section_header "Cabeceras HTTP"
    get_target || return
    if check_tool curl; then
        echo -e "${YELLOW}    [*] Obteniendo cabeceras de: ${WHITE}$TARGET${RESET}"
        echo ""
        curl -sI "https://${TARGET}" 2>/dev/null | sed 's/^/    /' | \
        GREP_COLOR='1;32' grep --color=always -iE "server|x-powered|content-type|strict-transport|x-frame|x-xss|content-security|." 
    fi
}

tool_traceroute() {
    section_header "Traceroute"
    get_target || return
    if check_tool traceroute; then
        echo -e "${YELLOW}    [*] Trazando ruta a: ${WHITE}$TARGET${RESET}"
        echo -e "${GRAY}    [*] Esto puede tardar unos segundos...${RESET}"
        echo ""
        traceroute -m 15 "$TARGET" 2>/dev/null | sed 's/^/    /'
    elif check_tool tracepath; then
        tracepath "$TARGET" 2>/dev/null | head -20 | sed 's/^/    /'
    fi
}

tool_ports() {
    section_header "Escaneo de Puertos Comunes"
    get_target || return
    echo -e "${RED}    [!] Solo usar en sistemas con autorización expresa.${RESET}"
    echo -en "${YELLOW}    [?] ¿Confirmas que tienes autorización? (s/N): ${WHITE}"
    read -r CONFIRM
    echo -e "${RESET}"
    if [[ "$CONFIRM" != "s" && "$CONFIRM" != "S" ]]; then
        echo -e "${RED}    [!] Cancelado.${RESET}"
        return
    fi
    if check_tool nmap; then
        echo -e "${YELLOW}    [*] Escaneando puertos comunes en: ${WHITE}$TARGET${RESET}"
        echo ""
        nmap -T3 --open -p 21,22,23,25,53,80,110,143,443,445,3306,3389,8080,8443 "$TARGET" 2>/dev/null | sed 's/^/    /'
    elif check_tool nc; then
        echo -e "${YELLOW}    [*] Verificando puertos básicos (sin nmap)...${RESET}"
        for port in 21 22 80 443 3306 8080; do
            if nc -z -w1 "$TARGET" "$port" 2>/dev/null; then
                echo -e "    ${GREEN}[ABIERTO]${RESET} Puerto $port"
            else
                echo -e "    ${RED}[CERRADO]${RESET} Puerto $port"
            fi
        done
    fi
}

tool_email_analysis() {
    section_header "Análisis de Email / Dominio"
    echo -en "${CYAN}    [>] Ingresa el dominio de email (ej: empresa.com): ${WHITE}"
    read -r DOMAIN
    echo -e "${RESET}"
    if [[ -z "$DOMAIN" ]]; then return; fi
    if check_tool dig; then
        echo -e "${YELLOW}    [*] Verificando configuración email de: ${WHITE}$DOMAIN${RESET}"
        echo ""
        echo -e "${CYAN}    -- Registros MX (Servidores de correo) --${RESET}"
        dig +short MX "$DOMAIN" 2>/dev/null | sed 's/^/    /'
        echo ""
        echo -e "${CYAN}    -- Registro SPF (Anti-spoofing) --${RESET}"
        dig +short TXT "$DOMAIN" 2>/dev/null | grep -i spf | sed 's/^/    /'
        echo ""
        echo -e "${CYAN}    -- Registro DMARC --${RESET}"
        dig +short TXT "_dmarc.${DOMAIN}" 2>/dev/null | sed 's/^/    /'
        echo ""
        echo -e "${CYAN}    -- Registro DKIM (default) --${RESET}"
        dig +short TXT "default._domainkey.${DOMAIN}" 2>/dev/null | sed 's/^/    /'
    fi
}

tool_subdomains() {
    section_header "Subdominios OSINT (certificados públicos)"
    get_target || return
    if check_tool curl; then
        echo -e "${YELLOW}    [*] Buscando subdominios de: ${WHITE}$TARGET${RESET}"
        echo -e "${GRAY}    [*] Fuente: crt.sh (certificados públicos SSL)${RESET}"
        echo ""
        curl -s "https://crt.sh/?q=%.${TARGET}&output=json" 2>/dev/null | \
        python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    names = sorted(set([d.get('name_value','') for d in data]))
    for n in names[:30]:
        for sub in n.split('\n'):
            if sub.strip():
                print('    \033[1;32m[+]\033[0m ' + sub.strip())
except:
    print('    \033[0;31m[!] No se pudo parsear la respuesta.\033[0m')
" 2>/dev/null || echo -e "${RED}    [!] Requiere Python3 y conexión a internet.${RESET}"
    fi
}

